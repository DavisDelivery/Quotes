{
  "name": "@davisdelivery/quote-generator",
  "private": true,
  "version": "0.9.2",
  "description": "Uline final-mile LTL quote generator for Davis Delivery Service. Reverse-engineered rate model (ZIP zone + per-CWT weight curve + skid/loose residual; fuel and margin on top). Runs standalone and embeds as a tab in other Davis apps.",
  "type": "module",
  "main": "./lib/quote-generator.js",
  "module": "./lib/quote-generator.js",
  "exports": {
    ".": {
      "import": "./lib/quote-generator.js"
    },
    "./model.json": "./src/model.json"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "preview": "vite preview --port 4173",
    "model": "python3 model/build/build_model.py"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
